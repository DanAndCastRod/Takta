# Takta Backend — Local Development Environment
# This file is loaded by db.py via python-dotenv.

# ── Database Mode ──
# "sqlite"  = Local SQLite file (default for development)
# "mssql"   = SQL Server (for staging/production)
DB_MODE=sqlite

# ── SQL Server Config (only used when DB_MODE=mssql) ──
MSSQL_SERVER=10.252.0.144
MSSQL_DATABASE=Takta
MSSQL_USER=proceso_opav
MSSQL_PASSWORD=Opav2022.

# ── SQLite Config (only used when DB_MODE=sqlite) ──
SQLITE_PATH=./takta.db

# ── App Config ──
APP_PORT=9003
LOG_LEVEL=INFO
